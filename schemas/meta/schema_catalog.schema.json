{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-development-framework.local/schemas/meta/schema_catalog.schema.json",
  "title": "ADF Meta Workflow Schema Catalog",
  "description": "Registry of operational contracts used by the V2 schema-driven meta-workflow.",
  "type": "object",
  "required": [
    "contract_name",
    "contract_version",
    "catalog_id",
    "updated_at",
    "contracts",
    "global_policies",
    "compatibility_matrix"
  ],
  "properties": {
    "contract_name": {
      "type": "string",
      "const": "schema_catalog"
    },
    "contract_version": {
      "type": "string",
      "const": "2.0"
    },
    "catalog_id": {
      "type": "string",
      "pattern": "^SCAT-[0-9]{8}-[0-9]{3}$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "contract_name",
          "contract_version",
          "path",
          "status"
        ],
        "properties": {
          "contract_name": {
            "type": "string",
            "minLength": 1
          },
          "contract_version": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^schemas/meta/[a-z0-9_.-]+\\.json$"
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated", "experimental"]
          },
          "owner": {
            "type": "string"
          },
          "consumers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "global_policies": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["policy_id", "path", "mode"],
        "properties": {
          "policy_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": ["reference"]
          }
        },
        "additionalProperties": false
      }
    },
    "compatibility_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "status"],
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^[a-z0-9_]+@[0-9]+\\.[0-9]+$"
          },
          "to": {
            "type": "string",
            "pattern": "^[a-z0-9_]+@[0-9]+\\.[0-9]+$"
          },
          "status": {
            "type": "string",
            "enum": ["compatible", "requires_migration", "incompatible"]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "human_summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
