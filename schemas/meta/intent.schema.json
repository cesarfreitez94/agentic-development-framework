{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-development-framework.local/schemas/meta/intent.schema.json",
  "title": "ADF User Intent",
  "description": "Structured user intent for the schema-driven meta-workflow.",
  "type": "object",
  "required": [
    "contract_name",
    "contract_version",
    "intent_id",
    "created_at",
    "source",
    "objective",
    "scope",
    "constraints",
    "requested_outputs"
  ],
  "properties": {
    "contract_name": {
      "type": "string",
      "const": "intent"
    },
    "contract_version": {
      "type": "string",
      "const": "2.0"
    },
    "intent_id": {
      "type": "string",
      "pattern": "^INTENT-[0-9]{8}-[0-9]{3}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": ["user", "system", "decision"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": ["include"],
      "properties": {
        "include": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requested_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "requires_user_confirmation": {
      "type": "boolean"
    },
    "related_milestone": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^M[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in_progress", "completed", "paused"]
        },
        "branch": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "human_summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
