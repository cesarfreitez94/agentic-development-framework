{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-development-framework.local/schemas/meta/git_operation.schema.json",
  "title": "ADF Git Operation",
  "description": "Requested and executed git operation record for the meta-workflow.",
  "type": "object",
  "required": [
    "contract_name",
    "contract_version",
    "operation_id",
    "created_at",
    "produced_by",
    "executed_by",
    "operation_type",
    "status",
    "source_refs",
    "branch",
    "policy_checks"
  ],
  "properties": {
    "contract_name": {
      "type": "string",
      "const": "git_operation"
    },
    "contract_version": {
      "type": "string",
      "const": "2.0"
    },
    "operation_id": {
      "type": "string",
      "pattern": "^GIT-[0-9]{8}-[0-9]{3}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "produced_by": {
      "type": "string",
      "enum": ["orchestrator", "review_gate"]
    },
    "executed_by": {
      "type": "string",
      "const": "git_operator"
    },
    "operation_type": {
      "type": "string",
      "enum": ["status_check", "create_branch", "commit", "push", "open_pr", "merge_pr"]
    },
    "status": {
      "type": "string",
      "enum": ["requested", "executed", "failed", "cancelled"]
    },
    "source_refs": {
      "type": "object",
      "required": ["review_report_id"],
      "properties": {
        "review_report_id": {
          "type": "string",
          "pattern": "^REV-[0-9]{8}-[0-9]{3}$"
        },
        "implementation_report_id": {
          "type": "string",
          "pattern": "^IMPL-[0-9]{8}-[0-9]{3}$"
        },
        "test_report_id": {
          "type": "string",
          "pattern": "^TEST-[0-9]{8}-[0-9]{3}$"
        },
        "decision_id": {
          "type": "string",
          "pattern": "^DEC-[0-9]{8}-[0-9]{3}$"
        },
        "plan_id": {
          "type": "string",
          "pattern": "^PLAN-[0-9]{8}-[0-9]{3}$"
        },
        "task_packet_id": {
          "type": "string",
          "pattern": "^TPACKET-[0-9]{8}-[0-9]{3}$"
        }
      },
      "additionalProperties": false
    },
    "branch": {
      "type": "object",
      "required": ["current", "base"],
      "properties": {
        "current": {
          "type": "string",
          "minLength": 1
        },
        "base": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "policy_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["policy_ref", "status"],
        "properties": {
          "policy_ref": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "not_applicable"]
          },
          "details": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "commit": {
      "type": "object",
      "properties": {
        "sha": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "issue_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "pull_request": {
      "type": "object",
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "remote": {
      "type": "string"
    },
    "requires_user_confirmation": {
      "type": "boolean"
    },
    "result": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string"
        },
        "exit_code": {
          "type": "integer"
        },
        "details": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "execution_notes": {
      "type": "string"
    },
    "human_summary": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": ["executed", "failed", "cancelled"]
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["result"]
      }
    },
    {
      "if": {
        "properties": {
          "operation_type": {
            "const": "merge_pr"
          }
        },
        "required": ["operation_type"]
      },
      "then": {
        "required": ["requires_user_confirmation"],
        "properties": {
          "requires_user_confirmation": {
            "const": true
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
