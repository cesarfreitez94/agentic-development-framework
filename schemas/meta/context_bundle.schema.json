{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-development-framework.local/schemas/meta/context_bundle.schema.json",
  "title": "ADF Context Bundle",
  "description": "Minimal context bundle with line ranges for execution.",
  "type": "object",
  "required": [
    "contract_name",
    "contract_version",
    "bundle_id",
    "packet_id",
    "created_at",
    "context_items",
    "excluded_context",
    "policy_refs",
    "integrity"
  ],
  "properties": {
    "contract_name": {
      "type": "string",
      "const": "context_bundle"
    },
    "contract_version": {
      "type": "string",
      "const": "2.0"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^CTX-[0-9]{8}-[0-9]{3}$"
    },
    "packet_id": {
      "type": "string",
      "pattern": "^TPACKET-[0-9]{8}-[0-9]{3}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "context_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "path", "line_ranges", "reason"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["schema", "policy", "roadmap", "state", "source_file", "test_file", "decision", "git"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "section": {
            "type": "string"
          },
          "line_ranges": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["start", "end"],
              "properties": {
                "start": {
                  "type": "integer",
                  "minimum": 1
                },
                "end": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": false
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "excluded_context": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "section": {
            "type": "string"
          },
          "line_ranges": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start", "end"],
              "properties": {
                "start": {
                  "type": "integer",
                  "minimum": 1
                },
                "end": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": false
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "policy_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "integrity": {
      "type": "object",
      "required": ["source_count", "truncated"],
      "properties": {
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "human_summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
