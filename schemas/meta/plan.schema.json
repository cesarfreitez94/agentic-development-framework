{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-development-framework.local/schemas/meta/plan.schema.json",
  "title": "ADF Execution Plan",
  "description": "Operational execution plan derived from the intent and roadmap slice.",
  "type": "object",
  "required": [
    "contract_name",
    "contract_version",
    "plan_id",
    "intent_id",
    "roadmap_slice_id",
    "created_at",
    "goal",
    "tasks",
    "acceptance_criteria",
    "constraints",
    "requires_user_confirmation"
  ],
  "properties": {
    "contract_name": {
      "type": "string",
      "const": "plan"
    },
    "contract_version": {
      "type": "string",
      "const": "2.0"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^PLAN-[0-9]{8}-[0-9]{3}$"
    },
    "intent_id": {
      "type": "string",
      "pattern": "^INTENT-[0-9]{8}-[0-9]{3}$"
    },
    "roadmap_slice_id": {
      "type": "string",
      "pattern": "^RSLICE-[0-9]{8}-[0-9]{3}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "title", "type", "depends_on"],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^TASK-[0-9]{8}-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "schema_design",
              "policy_constraints",
              "roadmap_slice",
              "plan",
              "task_packet",
              "context_bundle",
              "implementation",
              "test",
              "review",
              "git_operation"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^TASK-[0-9]{8}-[0-9]{3}$"
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "owner_hint": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires_user_confirmation": {
      "type": "boolean"
    },
    "estimated_order": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^TASK-[0-9]{8}-[0-9]{3}$"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_register": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk", "impact"],
        "properties": {
          "risk": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "mitigation": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "human_summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
